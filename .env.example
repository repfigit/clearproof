# === Required ===
PII_MASTER_KEY=          # 32+ byte key for PII encryption (hex-encoded recommended: 64 hex chars)

# === Optional (with defaults) ===
VASP_DID=did:web:vasp.example.com
CIRCUIT_ARTIFACTS_DIR=./artifacts
CORS_ALLOWED_ORIGINS=http://localhost:3000
SIWE_DOMAIN=localhost
HKDF_SALT=              # Random 32-byte salt (hex). Leave empty for default.

# === Deployment (contract operations only) ===
DEPLOYER_PRIVATE_KEY=    # Wallet private key for contract deployment
SEPOLIA_RPC_URL=         # Sepolia RPC endpoint (e.g., Alchemy/Infura)
