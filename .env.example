# Bittensor
BITTENSOR_WALLET_NAME=zk_travel_rule
BITTENSOR_WALLET_HOTKEY=default
BITTENSOR_SUBNET_UID=
BITTENSOR_NETWORK=test
BT_STUB=1

# ZK Circuit artifacts
CIRCUIT_PATH=./artifacts/compiled_circuit
PK_PATH=./artifacts/pk.key
VK_PATH=./artifacts/vk.key
SETTINGS_PATH=./artifacts/settings.json

# Targon CVM
TVM_ENDPOINT=https://tvm.targon.com/v1
TVM_API_KEY=
TVM_VERIFY_ATTESTATION=true
TVM_STUB=1

# Sanctions list (rebuild daily)
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
UN_SANCTIONS_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
EU_SANCTIONS_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content

# TRISA
TRISA_DIRECTORY_URL=api.vaspdirectory.net:443
TRISA_CERT_PATH=./certs/trisa.pem
TRISA_KEY_PATH=./certs/trisa.key
TRISA_STUB=1

# API
API_PORT=8000
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
